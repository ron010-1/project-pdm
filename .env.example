# URL base da API (criancaFeliz-pw1) rodando local em http://localhost:3333
# Emulador Android: use 10.0.2.2 no lugar de localhost
# iOS simulator / web / dispositivo físico na mesma rede: use o IP da máquina ou localhost
EXPO_PUBLIC_API_URL=http://localhost:3333

# URL base do microservico de upload de imagens (serviceImages), rodando local em http://localhost:3000
# Mesma regra de host: 10.0.2.2 no emulador Android, IP da máquina em dispositivo físico
EXPO_PUBLIC_IMAGE_SERVICE_URL=http://localhost:3000
